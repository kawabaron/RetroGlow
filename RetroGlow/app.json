{
  "expo": {
    "name": "RetroGlow",
    "slug": "RetroGlow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "retroglow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you choose an image for City Pop transformation.",
          "cameraPermission": "Allow RetroGlow to access your camera to take a photo."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "The app needs to save the generated image to your library.",
          "savePhotosPermission": "The app needs your permission to save photos."
        }
      ],
      "city-pop-processor"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}